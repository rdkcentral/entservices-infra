callsign    = "org.rdk.GstreamerService"
autostart   = "@PLUGIN_GSTREAMERSERVICE_AUTOSTART@"
startuporder = "@PLUGIN_GSTREAMERSERVICE_STARTUPORDER@"

configuration = JSON()
rootobject    = JSON()

rootobject.add("mode",    "@PLUGIN_GSTREAMERSERVICE_MODE@")
rootobject.add("locator", "lib@PLUGIN_IMPLEMENTATION@.so")
configuration.add("root", rootobject)
