set (autostart ${PLUGIN_GSTREAMERSERVICE_AUTOSTART})
set (preconditions Platform)
set (callsign "org.rdk.GstreamerService")

if(PLUGIN_GSTREAMERSERVICE_STARTUPORDER)
set (startuporder ${PLUGIN_GSTREAMERSERVICE_STARTUPORDER})
endif()

map()
   key(root)
   map()
       kv(mode ${PLUGIN_GSTREAMERSERVICE_MODE})
       kv(locator lib${PLUGIN_IMPLEMENTATION}.so)
   end()
end()
ans(configuration)
