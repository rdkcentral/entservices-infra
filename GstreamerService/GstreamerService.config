{
    "$schema": "plugin.schema.json",
    "info": {
        "title": "GstreamerService Plugin",
        "callsign": "org.rdk.GstreamerService",
        "locator": "libWPEFrameworkGstreamerService.so",
        "status": "production",
        "description": "GstreamerService plugin for managing GStreamer pipelines",
        "version": "1.0"
    },
    "configuration": {
        "type": "object",
        "properties": {
            "root": {
                "type": "object",
                "properties": {
                    "mode": {
                        "type": "string",
                        "description": "Mode of operation (Off, Local, Container)"
                    },
                    "locator": {
                        "type": "string",
                        "description": "Library location for the implementation"
                    }
                },
                "required": []
            }
        },
        "required": []
    }
}
